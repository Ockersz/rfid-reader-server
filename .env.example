# Local database
LOCAL_HOST=localhost
LOCAL_USER=root
LOCAL_PASSWORD=123
LOCAL_DB=rfid_db
LOCAL_PORT=3306

# Server database
SERVER_HOST=your_server_db_host
SERVER_USER=your_server_db_user
SERVER_PASSWORD=your_server_db_password
SERVER_DB=your_server_db_name
SERVER_PORT=3306

# Set true only if the app must crash when the server DB is unreachable at startup.
# Leave false to keep local RFID capture running and retry remote sync later.
SERVER_DB_REQUIRED=false

# Database pool / diagnostics
DB_SLOW_QUERY_THRESHOLD_MS=2000
DB_ACTIVE_CONNECTION_WARN_MS=60000
DB_POOL_DEBUG=false

LOCAL_DB_CONNECTION_LIMIT=5
LOCAL_DB_MAX_IDLE=0
LOCAL_DB_IDLE_TIMEOUT_MS=30000
LOCAL_DB_QUEUE_LIMIT=50
LOCAL_DB_CONNECT_TIMEOUT_MS=10000

SERVER_DB_CONNECTION_LIMIT=5
SERVER_DB_MAX_IDLE=0
SERVER_DB_IDLE_TIMEOUT_MS=30000
SERVER_DB_QUEUE_LIMIT=50
SERVER_DB_CONNECT_TIMEOUT_MS=10000

# Server ports
UDP_PORT=5001
HTTP_PORT=5002
